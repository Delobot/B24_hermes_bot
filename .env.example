# VibeCode API key (create at https://vibecode.bitrix24.tech/keys)
VIBE_API_KEY=vibe_api_YOUR_KEY_HERE

# Bot ID (auto-generated when creating bot via scripts/create_bot.py)
# BOT_ID=auto

# Bot name
BOT_NAME=HermesBot

# Poll interval (seconds)
POLL_INTERVAL=3

# Hermes model (from agent profile)
HERMES_MODEL=bitrix/bitrixgpt-5.5